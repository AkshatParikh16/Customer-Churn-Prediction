# ── Copy to .env and fill in real values ──────────────────────────────────────
# cp .env.example .env

# ── Data ─────────────────────────────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_TRAIN_FILENAME=cell2celltrain.csv
DATA_TEST_FILENAME=cell2celltest.csv
DATA_TARGET_COL=Churn
DATA_RANDOM_STATE=42
DATA_TEST_SIZE=0.20

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_CV_FOLDS=5
MODEL_XGB_N_ESTIMATORS=500
MODEL_XGB_MAX_DEPTH=6
MODEL_XGB_LEARNING_RATE=0.05
MODEL_XGB_SCALE_POS_WEIGHT=2.47
MODEL_DECISION_THRESHOLD=0.40
MODEL_OPTUNA_N_TRIALS=50

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db
MLFLOW_EXPERIMENT=customer-churn-cell2cell
MLFLOW_REGISTRY_NAME=churn-xgboost-prod

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_LOG_LEVEL=info
API_ENVIRONMENT=development
API_MODEL_URI=models/churn_xgb_prod.joblib

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ECR_REPOSITORY=customer-churn-prediction
AWS_ECR_REGISTRY=<your-account-id>.dkr.ecr.us-east-1.amazonaws.com
AWS_S3_BUCKET=churn-mlflow-artifacts

# ── Kaggle ────────────────────────────────────────────────────────────────────
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key
